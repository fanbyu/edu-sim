# LLM Provider Configuration
# 支持的提供商:
# - claude-cli: Claude Code CLI (默认)
# - codex-cli: Codex CLI
# - openai: OpenAI API (GPT-4, GPT-3.5)
# - qwen: 阿里云通义千问 (OpenAI 兼容)
# - doubao: 字节跳动豆包 (OpenAI 兼容)
# - any: 任意 OpenAI 兼容的 API
LLM_PROVIDER=claude-cli

# OpenAI-compatible API 配置 (用于 qwen/doubao/openai/any)
# API 密钥 (必需)
OPENAI_API_KEY=your_api_key_here

# API 基础 URL (可选，根据不同提供商自动设置)
# Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
# Doubao: https://ark.cn-beijing.volces.com/api/v3
# OpenAI: https://api.openai.com/v1
# OPENAI_BASE_URL=https://your-custom-api.com/v1

# 默认模型 (可选，根据不同提供商自动设置)
# Qwen: qwen-plus, qwen-max, qwen-turbo
# Doubao: doubao-pro-32k, doubao-lite-32k
# OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# OPENAI_MODEL=qwen-plus
